[alias]
    ba = branch -a --verbose
    ca = commit -q --amend --branch --status --verbose
    cf = checkout --quiet --force
    cl = clone --progress --verbose --recurse-submodules
    cm = commit --branch --status --verbose
    cn = gc --auto --prune
    cna = !"git reflog expire --all && git fsck --unreachable --full && git prune && \
        git gc --aggressive --quiet && git repack -Adq && git prune-packed --quiet"
    dt = difftool
    fe = fetch --progress
    mt = mergetool
    pf = !"git ph --force origin $(git branch-name)"
    ph = push --progress --set-upstream
    pl = pull
    re = reset
    rh = reset --hard
    rv = remote --verbose
    st = status

[branch]
    autoSetupMerge = always
    autoSetupRebase = always

[clean]
    requireForce = true

[color]
    branch = auto
    diff = auto
    grep = auto
    interactive = auto
    push = auto
    remote = auto
    showbranch = auto
    status = auto
    transport = auto

[color "branch"]
    current = green normal bold
    local = yellow normal bold
    plain = white normal bold
    remote = red normal bold

[color "status"]
    added = green normal bold
    updated = green normal bold
    changed = yellow normal bold
    nobranch = red white blink
    untracked = red normal bold

[commit]
    status = true

[core]
    autocrlf = input
    commitgraph = true
    eol = lf
    excludesfile = ~/.gitignore
    fsmonitor = true
    pager = delta
    preloadindex = true
    untrackedcache = true

[diff]
    context = 8
    ignoreSubmodules = all
    mnemonicprefix = true
    renameLimit = 8
    renames = copy

[fetch]
    output = compact
    prune = true
    pruneTags = true
    recurseSubmodules = true
    writeCommitGraph = true

[gc]
    pruneExpire = 7 days ago
    reflogExpireUnreachable = 7 days ago

[grep]
    lineNumber = true
    extendedRegexp = true

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only
    singlekey = true

[log]
    abbrevCommit = true
    date = iso
    follow = true
    showRoot = true

[merge]
    conflictStyle = zdiff3
    log = true
    renameLimit = 8
    renormalize = true
    stat = true
    tool = nvimdiff3

[mergetool]
    keepBackup = false
    writeToTemp = true

[pull]
    ff = only

[push]
    default = simple
    followTags = true
    recurseSubmodules = on-demand

[rebase]
    abbreviateCommands = true
    autoSquash = true
    autoStash = true
    stat = true

[status]
    relativePaths = false
    showStash = true
    showUntrackedFiles = all

[tag]
    sort = version:refname

[user]
    email = info@renatius.de
    name = René Six
    useConfigOnly = true

[include]
    path = ~/.git/delta.gitconfig

[include]
    path = ~/.gitconfig.local
